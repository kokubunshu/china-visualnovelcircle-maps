# VNFest 地图 — .dockerignore
# 构建镜像时排除本地开发文件和 git 数据

.git
.gitignore
.github/

# 本地开发工具
node_modules/
vendor/
*.md
DEPLOY.md

# Docker 相关
Dockerfile
docker-compose*.yml

# 配置文件（运行时不包含在镜像中，通过 volume 挂载）
config.php
deploy-config.sh
deploy-config.example.sh

# 运行时数据（通过 volume 挂载）
data/*.json
data/*.db
data/*.sqlite
data/avatars/
data/club_avatars/
data/publication_images/
data/event_images/
data/cache/
data/manuscripts/
uploads/
wiki/uploads/

# IDE 和系统文件
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
